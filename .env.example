# ── Supabase ───────────────────────────────────────────────────────────────
# Copy this file to `.env.local` and paste your project values.
# Find these in Supabase → Project Settings → API.
#
# Project URL  →  NEXT_PUBLIC_SUPABASE_URL
# anon public  →  NEXT_PUBLIC_SUPABASE_ANON_KEY   (safe for the browser)
#
# ⚠️  NEVER put the service_role key here or commit it anywhere.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
